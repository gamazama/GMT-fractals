<!-- Main Distance Estimator Function -->
<Shader_Function>
// Helper functions for Doyle Spirals
        #ifndef PI
        #define PI 3.14159265358979323846264
        #endif
        vec2 solve_doyle(vec2 z, int P, int Q){
            float k = float(P) / float(Q);
            for(int i = 0; i < 2; i++){
                float lb = z.x * k;
                float tb = z.y * k + 2.0 * PI / float(Q);
                float ra = exp(z.x), rb = exp(lb), ca = cos(z.y), cb = cos(tb), cab = cos(z.y - tb);
                
                vec3 v = vec3(
                    (ra*ra - 2.0*ra*ca + 1.0) / ((ra+1.0)*(ra+1.0)),
                    (rb*rb - 2.0*rb*cb + 1.0) / ((rb+1.0)*(rb+1.0)),
                    (ra*ra - 2.0*ra*rb*cab + rb*rb) / ((ra+rb)*(ra+rb))
                );
                vec2 f = v.xy - v.yz;
                
                vec3 c = 2.0 * vec3(
                    ra / ((ra+1.0)*(ra+1.0)), 
                    k * rb / ((rb+1.0)*(rb+1.0)), 
                    (1.0 - k) * ra * rb / ((ra+rb)*(ra+rb))
                );
                vec3 v0 = c * vec3(
                    (1.0 + ca) * (ra - 1.0) / (ra + 1.0), 
                    (1.0 + cb) * (rb - 1.0) / (rb + 1.0), 
                    (1.0 + cab) * (ra - rb) / (ra + rb)
                );
                vec3 v1 = c * sin(vec3(z.y, tb, z.y - tb));
                
                mat2 J;
                J[0] = v0.xy - v0.yz; 
                J[1] = v1.xy - v1.yz;
                
                float idet = 1.0 / (J[0][0]*J[1][1] - J[0][1]*J[1][0]);
                mat2 iJ = mat2(J[1][1], -J[0][1], -J[1][0], J[0][0]) * idet;
                
                z -= iJ * f;
            }
            return z;
        }

        void getDoyleConstants(int P, int Q, float SRadScl, out mat2 Mat, out mat2 iMat, out vec4 rads, out vec4 xps, out vec4 yps, out vec2 ns) {
            vec2 v = vec2(-float(P) + float(Q) * 0.5, float(Q) * sqrt(3.0) * 0.5);
            float vd = 1.0 / length(v);
            float scl = 2.0 * PI * vd;
            vec2 z = scl * vd * vec2(v.y, v.x);
            
            z = solve_doyle(z, P, Q);
            
            float k = float(P) / float(Q);
            vec2 zt = vec2(z.x * k, z.y * k + 2.0 * PI / float(Q));
            
            Mat[0] = z; 
            Mat[1] = zt;
            
            float det = Mat[0][0]*Mat[1][1] - Mat[0][1]*Mat[1][0];
            iMat = mat2(Mat[1][1], -Mat[0][1], -Mat[1][0], Mat[0][0]) / det;
            
            float ra = exp(z.x), rb = exp(zt.x), ca = cos(z.y);
            float rs = sqrt((ra*ra - 2.0*ra*ca + 1.0) / ((ra+1.0)*(ra+1.0)));
            rs *= SRadScl;
            
            rads = rs * vec4(1.0, ra, rb, ra*rb);
            xps = vec4(1.0, ra*ca, rb*cos(zt.y), ra*rb*cos(z.y+zt.y));
            yps = vec4(0.0, ra*sin(z.y), rb*sin(zt.y), ra*rb*sin(z.y+zt.y));
            ns = vec2(-rs, sqrt(1.0 - rs*rs));
        }

        float Doyle(vec3 z, mat2 Mat, mat2 iMat, vec4 rads, vec4 xps, vec4 yps, vec2 ns) {
            z.z = abs(z.z);
            vec2 p = vec2(length(z.xy), abs(z.z));
            float r = p.x;
            
            p -= ns * max(0.0, dot(ns, p));
            p = z.xy * p.x / r;
            
            p = vec2(log(length(p)), atan(p.y, p.x));
            vec2 pl = iMat * p;
            pl = pl - floor(pl);
            pl = Mat * pl;
            
            float scl = exp(pl.x - p.x);
            float angle = pl.y - p.y;
            
            z *= scl;
            float c = cos(angle), s = sin(angle);
            z.xy = vec2(z.x*c - z.y*s, z.x*s + z.y*c);
            
            vec4 vx = vec4(z.x) - xps;
            vec4 vy = vec4(z.y) - yps;
            vec4 vz = vec4(z.z);
            vec4 dists = sqrt(vx*vx + vy*vy + vz*vz) - rads;
            
            return min(min(dists.x, dists.y), min(dists.z, dists.w)) / scl;
        }

        float DE_Doyle(vec3 p, int P, int Q, float SRadScl, bool DoInversion, vec3 InvCenter, float InvRadius) {
            mat2 Mat, iMat;
            vec4 rads, xps, yps;
            vec2 ns;
            getDoyleConstants(P, Q, SRadScl, Mat, iMat, rads, xps, yps, ns);
            
            if(DoInversion){
                p = p - InvCenter;
                float r = length(p);
                float r2 = r * r;
                p = (InvRadius / r2) * p + InvCenter;
                float de = Doyle(p, Mat, iMat, rads, xps, yps, ns);
                de = r2 * de / (InvRadius + r * de);
                return de;
            } else {
                return Doyle(p, Mat, iMat, rads, xps, yps, ns);
            }
        }

        // Dummy formula body since we override getDist
        void formula_DoyleSpirals(inout vec4 z, inout float dr, inout float trap, vec4 c) {
            // Handled entirely in getDist
        }
</Shader_Function>

<!-- The Iteration Loop Body -->
<Shader_Loop>
formula_DoyleSpirals(z, dr, trap, c);
</Shader_Loop>

<!-- Optional: Custom Distance/Iteration Smoothing -->
<Shader_Dist>
int P = int(uParamA + 0.5);
            int Q = int(uParamB + 0.5);
            float SRadScl = uParamC;
            bool DoInversion = uParamD > 0.5;
            vec3 InvCenter = uJulia;
            float InvRadius = uParamE;
            
            float d = DE_Doyle(z.xyz, P, Q, SRadScl, DoInversion, InvCenter, InvRadius);
            return vec2(d, iter);
</Shader_Dist>

