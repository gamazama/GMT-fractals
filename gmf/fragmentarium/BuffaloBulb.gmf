  "id": "BuffaloBulb",
  "name": "Buffalo Bulb",
  "shortDescription": "A 3D Buffalo fractal variant with optional absolute value folding.",
  "description": "The Buffalo fractal ported from Fragmentarium by 3Dickulus. Based on the original formula by user youhn at http://www.fractalforums.com/gallery-b177/buffalo-fractals. Features configurable absolute value folding on each axis for generating unique bulb-like structures.",
  "parameters": [
    { "label": "Power", "id": "paramA", "min": 0, "max": 16, "step": 0.1, "default": 2, "description": "Mandelbulb-style power exponent" },
    { "label": "Scale", "id": "paramB", "min": 0.1, "max": 4, "step": 0.01, "default": 1, "description": "Additional scale factor" },
    { "label": "Rot Angle", "id": "paramC", "min": 0, "max": 6.283185, "step": 0.01, "default": 0, "scale": "2pi", "description": "Rotation around (1,1,1) axis" },
