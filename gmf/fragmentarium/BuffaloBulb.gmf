<!-- Main Distance Estimator Function -->
<Shader_Function>
void formula_BuffaloBulb(inout vec4 z, inout float dr, inout float trap, vec4 c) {
    vec3 p = z.xyz;
    
    float power = uParamA;
    float scale = uParamB;
    float rotAngle = uParamC;
    float absFlags = uParamD;
    float offsetZ = uParamE;
    float juliaW = uParamF;
    
    // Decode abs flags: bit 0-2 = absX,absY,absZ; bit 3-5 = preAbsX,preAbsY,preAbsZ
    bool absx = (mod(floor(absFlags / 1.0), 2.0) > 0.5);
    bool absy = (mod(floor(absFlags / 2.0), 2.0) > 0.5);
    bool absz = (mod(floor(absFlags / 4.0), 2.0) > 0.5);
    bool preabsx = (mod(floor(absFlags / 8.0), 2.0) > 0.5);
    bool preabsy = (mod(floor(absFlags / 16.0), 2.0) > 0.5);
    bool preabsz = (mod(floor(absFlags / 32.0), 2.0) > 0.5);
    
    // Pre-abs folding
    if (preabsx) p.x = abs(p.x);
    if (preabsy) p.y = abs(p.y);
    if (preabsz) p.z = abs(p.z);
    
    // Get current radius for derivative calculation
    float r = length(p);
    
    // Buffalo iteration
    float x2 = p.x * p.x;
    float y2 = p.y * p.y;
    float z2 = p.z * p.z;
    float temp = 1.0 - (z2 / (x2 + y2 + 1e-20));
    float newx = (x2 - y2) * temp;
    float newy = 2.0 * p.x * p.y * temp;
    float newz = -2.0 * p.z * sqrt(x2 + y2 + 1e-20);
    
    // Apply abs folding after iteration
    p.x = absx ? abs(newx) : newx;
    p.y = absy ? abs(newy) : newy;
    p.z = absz ? abs(newz) : newz;
    
    // Apply scale
    p *= scale;
    
    // Add Z offset
    p.z += offsetZ;
    
    // Add constant (Julia or Mandelbrot mode)
    vec3 cVal = uJuliaMode > 0.5 ? uJulia : c.xyz;
    // Include juliaW in the constant if needed
    cVal.z += juliaW;
    p += cVal;
    
    // Update derivative using current radius
    dr = dr * 2.0 * r * scale;
    
    // Apply rotation (around 1,1,1 axis)
    if (abs(rotAngle) > 0.001) {
        vec3 axis = normalize(vec3(1.0, 1.0, 1.0));
        float s = sin(rotAngle);
        float c_rot = cos(rotAngle);
        float oc = 1.0 - c_rot;
        mat3 rot = mat3(
            oc * axis.x * axis.x + c_rot,           oc * axis.x * axis.y - axis.z * s,  oc * axis.z * axis.x + axis.y * s,
            oc * axis.x * axis.y + axis.z * s,  oc * axis.y * axis.y + c_rot,           oc * axis.y * axis.z - axis.x * s,
            oc * axis.z * axis.x - axis.y * s,  oc * axis.y * axis.z + axis.x * s,  oc * axis.z * axis.z + c_rot
        );
        p *= rot;
    }
    
    z.xyz = p;
    trap = min(trap, length(p));
}
</Shader_Function>

<!-- The Iteration Loop Body -->
<Shader_Loop>
formula_BuffaloBulb(z, dr, trap, c);
</Shader_Loop>

<!-- Custom Distance Estimation - matches Fragmentarium's DE formula -->
<Shader_Dist>
float m2 = r * r;
if (m2 < 1.0e-20) return vec2(0.0, iter);

// Standard DE formula: 0.5 * log(r) * r / dr
float d = 0.5 * log(m2) * r / max(abs(dr), 1e-20);

// Smooth iteration count
float smoothIter = iter;
if (m2 > 1.0) {
    float threshLog = log2(max(uEscapeThresh, 1.1));
    smoothIter = iter + 1.0 - log2(log2(m2) / threshLog);
}

return vec2(d, smoothIter);
</Shader_Dist>
